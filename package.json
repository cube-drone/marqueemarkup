{
  "name": "marqueemarkup",
  "version": "0.4.0",
  "private": true,
  "description": "The Marquee markup language: spec, conformance vectors, and reference implementations",
  "type": "module",
  "workspaces": [
    "ts/marquee-parser",
    "ts/marquee-turbolink",
    "ts/marquee-turbolink-example-plugin",
    "ts/marquee-html-renderer",
    "ts/marquee-css",
    "ts/marquee-fonts",
    "ts/marquee-emoji",
    "ts/marquee-react-renderer",
    "ts/marquee-codemirror",
    "ts/marquee-markup",
    "editors/vscode-marquee"
  ],
  "scripts": {
    "test": "npm test --workspaces",
    "check": "npm run check --workspaces",
    "build": "npm run build --workspaces",
    "marquee": "node --conditions=marquee-src ts/marquee-markup/bin/marquee.ts",
    "set-version": "node scripts/set-version.ts",
    "release-check": "node scripts/release-check.ts",
    "release": "node scripts/publish.ts",
    "demo:react": "npm run demo --workspace=@cube-drone/marquee-react-renderer",
    "demo:cm": "npm run demo --workspace=@cube-drone/marquee-codemirror"
  }
}
