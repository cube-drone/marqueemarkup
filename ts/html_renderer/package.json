    "preview": "node scripts/preview.ts"
  },
  "dependencies": {
    "@classam/marquee-parser": "^0.1.0"
  },
  "devDependencies": {
    "@classam/marquee-css": "^0.1.0",
    "@classam/marquee-fonts": "^0.1.0",
    "@classam/turbolink": "^0.1.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
