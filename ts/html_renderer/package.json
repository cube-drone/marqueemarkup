{
  "name": "@classam/marquee-html-renderer",
  "version": "0.1.0",
  "description": "Reference static HTML renderer for the Marquee markup language",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cube-drone/marqueemarkup.git",
    "directory": "ts/html_renderer"
  },
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "files": [
    "src"
  ],
